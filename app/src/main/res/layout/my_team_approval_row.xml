<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_5sdp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_bgg"
        android:orientation="horizontal"
        android:padding="@dimen/_5sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_img"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:src="@drawable/ic_place_holder"
            app:layout_constraintBottom_toBottomOf="@+id/tv_employe_designation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_employe_name" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_employe_name"
            style="@style/TEXT_SEMI_BLACK_15"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:textAlignment="textStart"
            android:textSize="@dimen/_12sdp"
            app:layout_constraintBottom_toTopOf="@+id/tv_employe_designation"
            app:layout_constraintEnd_toStartOf="@+id/drop_down"
            app:layout_constraintStart_toEndOf="@id/profile_img"
            tools:text="Arslan" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_employe_designation"
            style="@style/TEXT_MEDIUM_BLACK_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="textStart"
            app:layout_constraintEnd_toStartOf="@+id/drop_down"
            app:layout_constraintStart_toStartOf="@+id/tv_employe_name"
            app:layout_constraintTop_toBottomOf="@+id/tv_employe_name"
            tools:text="Software engineer" />


        <ImageView
            android:id="@+id/drop_down"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp"
            android:src="@drawable/ic_down"
            app:layout_constraintBottom_toBottomOf="@+id/tv_employe_designation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_employe_name" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ly_attend_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_employe_designation"
            >

            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="@dimen/_1sdp"
                android:layout_margin="@dimen/_5sdp"
                android:background="@color/divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_from_date"
                style="@style/TEXT_MEDIUM_GREY_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:gravity="start"
                android:text="@string/time"
                android:textAllCaps="true"
                app:layout_constraintEnd_toStartOf="@+id/tv_to_date"
                app:layout_constraintStart_toStartOf="@+id/divider"
                app:layout_constraintTop_toBottomOf="@+id/divider" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_from_date_txt"
                style="@style/TEXT_MEDIUM_BLACK_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"

                android:background="@drawable/rounded_disabled"
                android:gravity="start"
                android:text="10-06-2024"
                app:layout_constraintEnd_toStartOf="@+id/tv_to_date_txt"
                app:layout_constraintStart_toStartOf="@+id/tv_from_date"
                app:layout_constraintTop_toBottomOf="@+id/tv_from_date" />


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_to_date"
                style="@style/TEXT_MEDIUM_GREY_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="@string/location"
                android:textAllCaps="true"
                app:layout_constraintEnd_toEndOf="@+id/divider"
                app:layout_constraintStart_toEndOf="@+id/tv_from_date"
                app:layout_constraintTop_toTopOf="@+id/tv_from_date" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_to_date_txt"
                style="@style/TEXT_MEDIUM_BLACK_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"

                android:background="@drawable/rounded_disabled"
                android:gravity="start"
                android:text="Location"
                app:layout_constraintEnd_toEndOf="@+id/divider"
                app:layout_constraintStart_toStartOf="@+id/tv_to_date"
                app:layout_constraintTop_toBottomOf="@+id/tv_to_date" />


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_leave_type"
                style="@style/TEXT_MEDIUM_GREY_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:layout_marginTop="@dimen/_5sdp"
                android:text="@string/attend_type"
                android:textAllCaps="true"
                app:layout_constraintEnd_toStartOf="@+id/tv_leave_approver"
                app:layout_constraintStart_toStartOf="@+id/divider"
                app:layout_constraintTop_toBottomOf="@id/tv_from_date_txt" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_leave_type_txt"
                style="@style/TEXT_MEDIUM_BLACK_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"

                android:background="@drawable/rounded_disabled"
                android:gravity="start"
                android:text="Sick Leave"
                app:layout_constraintEnd_toStartOf="@+id/tv_leave_approver_txt"
                app:layout_constraintStart_toStartOf="@+id/tv_leave_type"
                app:layout_constraintTop_toBottomOf="@+id/tv_leave_type" />


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_leave_approver"
                style="@style/TEXT_MEDIUM_GREY_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="@string/status"
                android:textAllCaps="true"
                app:layout_constraintEnd_toEndOf="@+id/divider"
                app:layout_constraintStart_toEndOf="@+id/tv_leave_type"
                app:layout_constraintTop_toTopOf="@+id/tv_leave_type" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_leave_approver_txt"
                style="@style/TEXT_MEDIUM_BLACK_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_disabled"
                android:ellipsize="end"
                android:gravity="start"
                android:lines="1"
                android:text="Un Paid"
                android:textColor="@color/red"
                app:layout_constraintEnd_toEndOf="@+id/divider"
                app:layout_constraintStart_toEndOf="@+id/tv_leave_type_txt"
                app:layout_constraintTop_toBottomOf="@+id/tv_leave_approver" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_reason"
                style="@style/TEXT_MEDIUM_GREY_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:text="@string/reason"
                android:gravity="start"
                android:textAllCaps="true"
                app:layout_constraintEnd_toEndOf="@+id/divider"
                app:layout_constraintStart_toStartOf="@+id/divider"
                app:layout_constraintTop_toBottomOf="@id/tv_leave_type_txt" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_reason_txt"
                style="@style/TEXT_MEDIUM_BLACK_10"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/rounded_disabled"
                android:gravity="start|center"
                app:layout_constraintEnd_toEndOf="@+id/divider"
                app:layout_constraintStart_toStartOf="@+id/tv_reason"
                app:layout_constraintTop_toBottomOf="@+id/tv_reason"
                tools:text="I am not feeling well because i am having fever and stomach issues" />
            <View
                android:id="@+id/btn_divider"
                android:layout_width="0dp"
                android:layout_height="@dimen/_1sdp"
                android:layout_margin="@dimen/_5sdp"
                android:background="@color/divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_reason_txt" />
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_reject"
                    style="@style/TEXT_REGULAR_BLACK_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_leave_cancelled"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_6sdp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:text="@string/reject"
                    app:layout_constraintEnd_toStartOf="@+id/tv_approved"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btn_divider"
                    android:layout_marginBottom="@dimen/_5sdp"
                    />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_approved"
                    style="@style/TEXT_REGULAR_WHITE_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:background="@drawable/rounded_enabled"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_6sdp"
                    android:text="@string/approved"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tv_reject"
                    app:layout_constraintStart_toEndOf="@+id/tv_reject" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>