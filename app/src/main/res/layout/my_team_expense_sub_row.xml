<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_5sdp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ly_attend_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="@dimen/_1sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_marginEnd="@dimen/_5sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_no"
            style="@style/TEXT_MEDIUM_BLACK_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:text="1_"
            android:textAllCaps="true"
            app:layout_constraintStart_toStartOf="@+id/divider"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_from_date"
            style="@style/TEXT_MEDIUM_GREY_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:gravity="start"
            android:text="@string/expense_type"
            android:textAllCaps="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_no"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_from_date_txt"
            style="@style/TEXT_MEDIUM_BLACK_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_disabled"
            android:gravity="start"
            android:text=""

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/tv_from_date"
            app:layout_constraintTop_toBottomOf="@+id/tv_from_date" />


        <LinearLayout
            android:id="@+id/ly_amount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="1"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_marginTop="@dimen/_5sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_no"
            app:layout_constraintTop_toBottomOf="@+id/tv_from_date_txt">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".5"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_to_date"
                    style="@style/TEXT_MEDIUM_GREY_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/expense_date"
                    android:textAllCaps="true"
                    app:layout_constraintEnd_toStartOf="@+id/tv_amount"
                    app:layout_constraintStart_toEndOf="@+id/tv_from_date"
                    app:layout_constraintTop_toTopOf="@+id/tv_from_date" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_to_date_txt"
                    style="@style/TEXT_MEDIUM_BLACK_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_disabled"
                    android:gravity="start"
                    android:text="2024-06-11"
                    app:layout_constraintStart_toEndOf="@+id/tv_from_date_txt"
                    app:layout_constraintTop_toBottomOf="@+id/tv_to_date" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".5"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_amount"
                    style="@style/TEXT_MEDIUM_GREY_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:text="@string/amount"
                    android:textAllCaps="true"/>


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_amount_txt"
                    style="@style/TEXT_MEDIUM_BLACK_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_disabled"
                    android:gravity="start|center"
                    app:layout_constraintEnd_toEndOf="@+id/divider"
                    app:layout_constraintStart_toEndOf="@+id/tv_to_date_txt"
                    app:layout_constraintTop_toBottomOf="@+id/tv_amount"
                    tools:text="10000" />
            </LinearLayout>

        </LinearLayout>


        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_reason"
            style="@style/TEXT_MEDIUM_GREY_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginStart="@dimen/_5sdp"
            android:gravity="start"
            android:text="@string/description"
            android:textAllCaps="true"
            app:layout_constraintEnd_toEndOf="@+id/divider"
            app:layout_constraintStart_toEndOf="@+id/tv_no"
            app:layout_constraintTop_toBottomOf="@id/ly_amount" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_reason_txt"
            style="@style/TEXT_MEDIUM_BLACK_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:background="@drawable/rounded_disabled"
            android:gravity="start|center"
            app:layout_constraintEnd_toEndOf="@+id/divider"
            app:layout_constraintStart_toStartOf="@+id/tv_reason"
            app:layout_constraintTop_toBottomOf="@+id/tv_reason"
            tools:text="I am not feeling well because i am having fever and stomach issues" />


        <View
            android:id="@+id/btn_divider"
            android:layout_width="0dp"
            android:layout_height="@dimen/_1sdp"
            android:layout_margin="@dimen/_5sdp"
            android:background="@color/divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_reason_txt" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>