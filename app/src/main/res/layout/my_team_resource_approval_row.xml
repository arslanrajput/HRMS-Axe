<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/_5sdp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_bgg"
        android:orientation="horizontal"
        android:padding="@dimen/_5sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_img"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:src="@drawable/ic_place_holder"
            app:layout_constraintBottom_toBottomOf="@+id/tv_employe_designation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_employe_name" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_employe_name"
            style="@style/TEXT_SEMI_BLACK_15"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:textAlignment="textStart"
            android:textSize="@dimen/_12sdp"
            app:layout_constraintBottom_toTopOf="@+id/tv_employe_designation"
            app:layout_constraintEnd_toStartOf="@+id/drop_down"
            app:layout_constraintStart_toEndOf="@id/profile_img"
            tools:text="Arslan" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_employe_designation"
            style="@style/TEXT_MEDIUM_GREY_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="textStart"
            app:layout_constraintStart_toStartOf="@+id/tv_employe_name"
            app:layout_constraintTop_toBottomOf="@+id/tv_employe_name"
            tools:text="Software engineer" />

        <View
            android:id="@+id/line_divider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="@color/grey"
            android:layout_marginStart="@dimen/_5sdp"
            app:layout_constraintTop_toTopOf="@+id/tv_employe_designation"
            app:layout_constraintBottom_toBottomOf="@+id/tv_employe_designation"
            app:layout_constraintStart_toEndOf="@+id/tv_employe_designation">

        </View>


        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_posting"
            style="@style/TEXT_MEDIUM_GREY_10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="textStart"
            android:layout_marginStart="@dimen/_5sdp"
            app:layout_constraintStart_toEndOf="@+id/line_divider"
            app:layout_constraintEnd_toStartOf="@+id/drop_down"
            app:layout_constraintTop_toBottomOf="@+id/tv_employe_name"
            tools:text="Software engineer"
            android:lines="1"
            android:ellipsize="end"/>


        <ImageView
            android:id="@+id/drop_down"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="@dimen/_5sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:src="@drawable/ic_down"
            app:layout_constraintEnd_toStartOf="@+id/view_expand"
            app:layout_constraintTop_toTopOf="@+id/tv_employe_name" />

        <CheckBox
            android:id="@+id/view_expand"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_marginEnd="@dimen/_5sdp"
            app:layout_constraintTop_toTopOf="@+id/drop_down"
            app:layout_constraintBottom_toBottomOf="@+id/drop_down"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ly_attend_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_employe_designation"
            >

            <View
                android:id="@+id/divider"
                android:layout_width="0dp"
                android:layout_height="@dimen/_1sdp"
                android:layout_margin="@dimen/_5sdp"
                android:background="@color/divider"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_leave_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/divider"
                tools:itemCount="2"
                android:layout_marginTop="@dimen/_5sdp"
                tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                tools:listitem="@layout/my_team_expense_sub_row"
                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_attachments"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:spanCount="3"
                tools:itemCount="3"
                android:visibility="gone"
                tools:listitem="@layout/attachment_row"
                app:layout_constraintTop_toBottomOf="@+id/rv_leave_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                >

            </androidx.recyclerview.widget.RecyclerView>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_reject"
                    style="@style/TEXT_REGULAR_BLACK_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_leave_cancelled"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_6sdp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:text="@string/reject"
                    android:visibility="gone"
                    app:layout_constraintEnd_toStartOf="@+id/tv_approved"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/rv_attachments"
                    android:layout_marginBottom="@dimen/_5sdp"
                    />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_approved"
                    style="@style/TEXT_REGULAR_WHITE_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_5sdp"
                    android:background="@drawable/rounded_enabled"
                    android:paddingTop="@dimen/_6sdp"
                    android:paddingBottom="@dimen/_6sdp"
                    android:text="@string/approved"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tv_reject"
                    app:layout_constraintStart_toEndOf="@+id/tv_reject" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>