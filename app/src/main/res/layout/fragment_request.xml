<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/start_guideline"
            style="@style/start_gl"
            android:orientation="vertical" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/end_guideline"
            style="@style/end_gl"
            android:orientation="vertical" />


        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/bottom_guideline"
            style="@style/bottom_gl" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/top_guideline"
            style="@style/top_gl" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_title"
            style="@style/TEXT_SEMI_BLACK_15"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="@string/request"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintEnd_toEndOf="@id/end_guideline"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="@+id/iv_back" />

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_left"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_guideline" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ly_action_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:background="@drawable/rounded_leave_filter"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="@dimen/_3sdp"
            app:layout_constraintEnd_toEndOf="@+id/end_guideline"
            app:layout_constraintStart_toStartOf="@id/start_guideline"
            app:layout_constraintTop_toBottomOf="@+id/iv_back">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_week"
                style="@style/TEXT_REGULAR_WHITE_10"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/rounded_enabled"
                android:paddingTop="@dimen/_6sdp"
                android:paddingBottom="@dimen/_6sdp"
                android:text="@string/leave_req"
                app:layout_constraintEnd_toStartOf="@+id/tv_month"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_month"
                style="@style/TEXT_REGULAR_BLACK_10"
                android:layout_width="0dp"

                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_5sdp"
                android:background="@drawable/rounded_disabled"
                android:paddingTop="@dimen/_6sdp"
                android:paddingBottom="@dimen/_6sdp"
                android:text="@string/attendance_req"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/tv_week" />
        </androidx.constraintlayout.widget.ConstraintLayout>



        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            android:background="@drawable/rounded_leave_filter"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_10sdp"

            app:layout_constraintBottom_toTopOf="@id/cv_container"
            app:layout_constraintStart_toStartOf="@+id/start_guideline"
            app:layout_constraintEnd_toEndOf="@+id/end_guideline"
            app:layout_constraintTop_toBottomOf="@+id/ly_action_btn">
         <androidx.constraintlayout.widget.ConstraintLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             >

             <!-- leave request!-->

             <androidx.constraintlayout.widget.ConstraintLayout
                 android:id="@+id/ly_create_leave"
                 android:visibility="visible"
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintBottom_toBottomOf="parent"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:paddingBottom="@dimen/_10sdp"
                 android:orientation="vertical">

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_header"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:background="@drawable/rounded_shifts"
                     android:backgroundTint="#DFEBF5"
                     android:gravity="center"
                     android:padding="@dimen/_8sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toTopOf="parent">

                     <ImageView
                         android:id="@+id/iv_today"
                         style="@style/TEXT_REGULAR_WHITE_10"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:layout_marginStart="@dimen/_3sdp"
                         android:background="@drawable/circle_no_bg"
                         android:backgroundTint="@color/white"
                         android:padding="@dimen/_2sdp"
                         android:src="@drawable/ic_alarm_snooz"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="parent"
                         tools:ignore="ContentDescription" />

                     <com.google.android.material.textview.MaterialTextView
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="0dp"
                         android:layout_height="match_parent"
                         android:layout_marginStart="@dimen/_5sdp"
                         android:text="@string/create_leave_req"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintStart_toEndOf="@+id/iv_today"
                         app:layout_constraintTop_toTopOf="parent" />
                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <com.google.android.material.textview.MaterialTextView
                     android:id="@+id/tv_leave_type"
                     style="@style/TEXT_MEDIUM_BLACK_10"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:layout_margin="@dimen/_5sdp"
                     android:text="@string/leave_type"
                     android:textAlignment="textStart"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@id/ly_header" />

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_leave_type"
                     android:layout_width="0dp"
                     android:layout_height="@dimen/_40sdp"
                     android:layout_marginTop="@dimen/_5sdp"
                     android:layout_marginEnd="@dimen/_5sdp"
                     android:background="@drawable/rounded_leave_filter"
                     android:orientation="vertical"
                     android:padding="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="@+id/tv_leave_type"
                     app:layout_constraintTop_toBottomOf="@+id/tv_leave_type">


                     <Spinner
                         android:id="@+id/sp_leave_type"
                         android:layout_width="0dp"
                         android:layout_height="match_parent"
                         android:overlapAnchor="false"
                         android:padding="@dimen/_2sdp"
                         android:popupBackground="@drawable/ly_spiner_bg"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintHorizontal_bias="1.0"
                         app:layout_constraintStart_toStartOf="parent"
                         tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck"
                         tools:listitem="@layout/spinner_item" />

                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_range_date"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@+id/ly_leave_type">

                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_start_date"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_margin="@dimen/_5sdp"
                         android:text="@string/start_date"
                         android:textAlignment="textStart"
                         app:layout_constraintEnd_toEndOf="@+id/divider_absent"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="parent" />

                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_start_date"
                         android:layout_width="0dp"
                         android:layout_height="@dimen/_40sdp"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         app:layout_constraintEnd_toStartOf="@+id/divider_absent"
                         app:layout_constraintStart_toStartOf="@+id/tv_start_date"
                         app:layout_constraintTop_toBottomOf="@+id/tv_start_date">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_start_date_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="@dimen/_5sdp"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:hint="@string/start_date"
                             android:textAlignment="textStart"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintStart_toEndOf="@+id/img_start_cal"
                             app:layout_constraintTop_toTopOf="parent" />

                         <ImageView
                             android:id="@+id/img_start_cal"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:layout_marginEnd="@dimen/_5sdp"
                             android:src="@drawable/ic_calendar"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintStart_toStartOf="parent"
                             app:layout_constraintTop_toTopOf="parent"
                             android:contentDescription="@string/todo">

                         </ImageView>
                     </androidx.constraintlayout.widget.ConstraintLayout>

                     <View
                         android:id="@+id/divider_absent"
                         android:layout_width="2dp"
                         android:layout_height="0dp"
                         android:layout_gravity="center_vertical"
                         android:layout_margin="@dimen/_5sdp"
                         android:background="@color/line_divider"
                         app:layout_constraintBottom_toBottomOf="@+id/ly_end_date"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="@+id/ly_end_date" />


                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_end_date"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:text="@string/end_date"
                         android:textAlignment="textStart"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="@+id/ly_end_date"
                         app:layout_constraintTop_toTopOf="parent" />

                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_end_date"
                         android:layout_width="0dp"
                         android:layout_height="@dimen/_40sdp"
                         android:layout_marginStart="@dimen/_5sdp"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toEndOf="@+id/divider_absent"
                         app:layout_constraintTop_toBottomOf="@+id/tv_end_date">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_end_date_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="@dimen/_5sdp"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:hint="@string/end_date"
                             android:textAlignment="textStart"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintStart_toEndOf="@+id/img_end_cal"
                             app:layout_constraintTop_toTopOf="parent" />

                         <ImageView
                             android:id="@+id/img_end_cal"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:src="@drawable/ic_calendar"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintStart_toStartOf="parent" />
                     </androidx.constraintlayout.widget.ConstraintLayout>

                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_leave_count_remain"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@+id/ly_halfday"
                     >

                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_leave_count"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_margin="@dimen/_5sdp"
                         android:text="@string/leave_count"
                         android:textAlignment="textStart"
                         app:layout_constraintEnd_toEndOf="@+id/divider_leave"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="parent" />

                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_leave_count"
                         android:layout_width="0dp"
                         android:layout_height="@dimen/_40sdp"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         app:layout_constraintEnd_toStartOf="@+id/divider_leave"
                         app:layout_constraintStart_toStartOf="@+id/tv_leave_count"
                         app:layout_constraintTop_toBottomOf="@+id/tv_leave_count">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_leave_count_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:hint="0"
                             android:textAlignment="textStart"
                             app:layout_constraintStart_toStartOf="parent"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintTop_toTopOf="parent"
                             />

                     </androidx.constraintlayout.widget.ConstraintLayout>

                     <View
                         android:id="@+id/divider_leave"
                         android:layout_width="2dp"
                         android:layout_height="0dp"
                         android:layout_gravity="center_vertical"
                         android:layout_margin="@dimen/_5sdp"
                         android:background="@color/line_divider"
                         app:layout_constraintBottom_toBottomOf="@+id/ly_remaining_leave"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="@+id/ly_remaining_leave" />


                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_remaining_leave"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:text="@string/remaining_leave"
                         android:textAlignment="textStart"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="@+id/ly_remaining_leave"
                         app:layout_constraintTop_toTopOf="parent" />

                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_remaining_leave"
                         android:layout_width="0dp"
                         android:layout_height="@dimen/_40sdp"
                         android:layout_marginStart="@dimen/_5sdp"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toEndOf="@+id/divider_leave"
                         app:layout_constraintTop_toBottomOf="@+id/tv_remaining_leave">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_remaining_leave_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:hint="0"
                             android:textAlignment="textStart"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintStart_toStartOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintTop_toTopOf="parent" />
                     </androidx.constraintlayout.widget.ConstraintLayout>

                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <CheckBox
                     android:id="@+id/half_day"
                     style="@style/CheckBoxStyle"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@+id/ly_range_date"
                     android:text="@string/half_day"
                     android:textSize="@dimen/_10ssp"
                     android:layout_margin="@dimen/_5sdp">
                 </CheckBox>

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_halfday"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:visibility="gone"
                     android:layout_marginTop="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@+id/half_day">

                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_halfday_date"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:layout_margin="@dimen/_5sdp"
                         android:text="@string/half_day_date"
                         android:textAlignment="textStart"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="parent" />

                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_halfday_date"
                         android:layout_width="0dp"
                         android:layout_height="@dimen/_40sdp"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="@+id/tv_halfday_date"
                         app:layout_constraintTop_toBottomOf="@+id/tv_halfday_date">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_half_date_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="@dimen/_5sdp"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:hint="@string/select_half_day"
                             android:textAlignment="textStart"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintStart_toEndOf="@+id/img_half_cal"
                             app:layout_constraintTop_toTopOf="parent" />

                         <ImageView
                             android:id="@+id/img_half_cal"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:layout_marginEnd="@dimen/_5sdp"
                             android:src="@drawable/ic_calendar"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintStart_toStartOf="parent"
                             app:layout_constraintTop_toTopOf="parent"
                             android:contentDescription="@string/todo">

                         </ImageView>
                     </androidx.constraintlayout.widget.ConstraintLayout>
                 </androidx.constraintlayout.widget.ConstraintLayout>



                 <com.google.android.material.textview.MaterialTextView
                     android:id="@+id/tv_reason_header"
                     style="@style/TEXT_MEDIUM_BLACK_10"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_margin="@dimen/_5sdp"
                     android:text="@string/reason_for_leave"
                     app:layout_constraintBottom_toTopOf="@+id/til_leave_reason"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@id/ly_leave_count_remain" />


                 <com.google.android.material.textfield.TextInputLayout
                     android:id="@+id/til_leave_reason"
                     style="@style/OutlinedTextInputLayoutReason"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="@dimen/_10sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     android:layout_marginEnd="@dimen/_5sdp"
                     app:layout_constraintStart_toStartOf="@+id/tv_reason_header"
                     app:layout_constraintTop_toBottomOf="@+id/tv_reason_header">

                     <com.google.android.material.textfield.TextInputEditText
                         android:id="@+id/et_leave_reason"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:gravity="start|top"
                         android:inputType="textMultiLine"
                         android:minLines="4"
                         android:maxLines="8"
                         android:hint="@string/write_reason"
                         android:singleLine="false"
                         tools:text="asdjklaahsd"
                         android:textColorHint="@color/grey" />

                 </com.google.android.material.textfield.TextInputLayout>



             </androidx.constraintlayout.widget.ConstraintLayout>

             <!-- attendance request!-->

             <androidx.constraintlayout.widget.ConstraintLayout
                 android:id="@+id/ly_create_attend"
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintBottom_toBottomOf="parent"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:paddingBottom="@dimen/_10sdp"
                 android:visibility="gone"
                 android:orientation="vertical">

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_attend_header"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:background="@drawable/rounded_shifts"
                     android:backgroundTint="#DFEBF5"
                     android:gravity="center"
                     android:padding="@dimen/_8sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toTopOf="parent">

                     <ImageView
                         android:id="@+id/iv_attend_today"
                         style="@style/TEXT_REGULAR_WHITE_10"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:layout_marginStart="@dimen/_3sdp"
                         android:background="@drawable/circle_no_bg"
                         android:backgroundTint="@color/white"
                         android:padding="@dimen/_2sdp"
                         android:src="@drawable/ic_alarm_snooz"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="parent"
                         tools:ignore="ContentDescription" />

                     <com.google.android.material.textview.MaterialTextView
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="0dp"
                         android:layout_height="match_parent"
                         android:layout_marginStart="@dimen/_5sdp"
                         android:text="@string/create_attend_req"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintStart_toEndOf="@+id/iv_attend_today"
                         app:layout_constraintTop_toTopOf="parent" />
                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <com.google.android.material.textview.MaterialTextView
                     android:id="@+id/tv_attend_type"
                     style="@style/TEXT_MEDIUM_BLACK_10"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:layout_margin="@dimen/_5sdp"
                     android:text="@string/attend_type"
                     android:textAlignment="textStart"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@id/ly_attend_header" />

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_attend_type"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="@dimen/_5sdp"
                     android:background="@drawable/rounded_leave_filter"
                     android:orientation="vertical"
                     android:padding="@dimen/_5sdp"
                     android:layout_marginEnd="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="@+id/tv_attend_type"
                     app:layout_constraintTop_toBottomOf="@+id/tv_attend_type">


                     <Spinner
                         android:id="@+id/sp_attend_type"
                         android:layout_width="0dp"
                         android:layout_height="match_parent"
                         android:overlapAnchor="false"
                         android:padding="@dimen/_2sdp"
                         tools:listitem="@layout/spinner_item"
                         android:popupBackground="@drawable/ly_spiner_bg"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <com.google.android.material.textview.MaterialTextView
                     android:id="@+id/tv_loc_type"
                     style="@style/TEXT_MEDIUM_BLACK_10"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:layout_margin="@dimen/_5sdp"
                     android:text="@string/location"
                     android:textAlignment="textStart"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@id/ly_attend_type" />

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:id="@+id/ly_loc_type"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="@dimen/_5sdp"
                     android:layout_marginEnd="@dimen/_5sdp"
                     android:background="@drawable/rounded_leave_filter"
                     android:orientation="vertical"
                     android:padding="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="@+id/tv_loc_type"
                     app:layout_constraintTop_toBottomOf="@+id/tv_loc_type">


                     <Spinner
                         android:id="@+id/sp_loc_type"
                         android:layout_width="0dp"
                         android:layout_height="match_parent"
                         android:overlapAnchor="false"
                         android:padding="@dimen/_2sdp"
                         tools:listitem="@layout/spinner_item"
                         android:popupBackground="@drawable/ly_spiner_bg"
                         app:layout_constraintBottom_toBottomOf="parent"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                 </androidx.constraintlayout.widget.ConstraintLayout>

                 <LinearLayout
                     android:id="@+id/ll_date"
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:orientation="horizontal"
                     android:weightSum="2"
                     app:layout_constraintTop_toBottomOf="@+id/ly_loc_type"
                     app:layout_constraintStart_toStartOf="parent"
                     >

                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_date"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_margin="@dimen/_5sdp"
                         android:text="@string/date"
                         android:textAlignment="textStart"
                         android:layout_weight="1"
                       />

                     <com.google.android.material.textview.MaterialTextView
                         android:id="@+id/tv_time"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_margin="@dimen/_5sdp"
                         android:text="@string/time"
                         android:layout_weight="1"
                         android:textAlignment="textStart"
                         />
                 </LinearLayout>


                 <LinearLayout
                     android:id="@+id/ll_dd"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:weightSum="2"
                     app:layout_constraintStart_toStartOf="@+id/ll_date"

                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintTop_toBottomOf="@+id/ll_date"
                     android:orientation="horizontal"
                     android:baselineAligned="false">

                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_date"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         android:layout_weight="1">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_date_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="@dimen/_5sdp"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:hint="@string/date"
                             android:textAlignment="textStart"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintStart_toEndOf="@+id/img_date_cal"
                             app:layout_constraintTop_toTopOf="parent" />

                         <ImageView
                             android:id="@+id/img_date_cal"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:layout_marginEnd="@dimen/_5sdp"
                             android:src="@drawable/ic_calendar"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintStart_toStartOf="parent"
                             app:layout_constraintTop_toTopOf="parent">

                         </ImageView>
                     </androidx.constraintlayout.widget.ConstraintLayout>


                     <androidx.constraintlayout.widget.ConstraintLayout
                         android:id="@+id/ly_time"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="@dimen/_5sdp"
                         android:layout_marginEnd="@dimen/_5sdp"
                         android:background="@drawable/rounded_leave_filter"
                         android:orientation="vertical"
                         android:padding="@dimen/_8sdp"
                         android:layout_weight="1">


                         <com.google.android.material.textview.MaterialTextView
                             android:id="@+id/tv_time_txt"
                             style="@style/TEXT_MEDIUM_BLACK_10"
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="@dimen/_5sdp"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:hint="@string/time"
                             android:textAlignment="textStart"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintEnd_toEndOf="parent"
                             app:layout_constraintStart_toEndOf="@+id/img_time_cal"
                             app:layout_constraintTop_toTopOf="parent" />

                         <ImageView
                             android:id="@+id/img_time_cal"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginTop="@dimen/_3sdp"
                             android:layout_marginEnd="@dimen/_5sdp"
                             android:src="@drawable/ic_calendar"
                             app:layout_constraintBottom_toBottomOf="parent"
                             app:layout_constraintStart_toStartOf="parent"
                             app:layout_constraintTop_toTopOf="parent">

                         </ImageView>
                     </androidx.constraintlayout.widget.ConstraintLayout>


                 </LinearLayout>

                 <com.google.android.material.textview.MaterialTextView
                     android:id="@+id/tv_attend_reason_header"
                     style="@style/TEXT_MEDIUM_BLACK_10"
                     android:layout_width="0dp"
                     android:layout_height="wrap_content"
                     android:layout_margin="@dimen/_5sdp"
                     android:text="@string/reason"
                     app:layout_constraintStart_toStartOf="parent"
                     app:layout_constraintTop_toBottomOf="@id/ll_dd" />

                 <com.google.android.material.textfield.TextInputLayout
                     android:id="@+id/til_attendance_reason"
                     style="@style/OutlinedTextInputLayoutReason"

                     android:layout_width="0dp"
                     android:gravity="start|top"
                     android:layout_height="wrap_content"
                     android:layout_marginTop="@dimen/_2sdp"
                     android:layout_marginEnd="@dimen/_5sdp"
                     app:layout_constraintEnd_toEndOf="parent"
                     app:layout_constraintStart_toStartOf="@+id/tv_attend_reason_header"
                     app:layout_constraintTop_toBottomOf="@+id/tv_attend_reason_header">

                     <com.google.android.material.textfield.TextInputEditText
                         android:id="@+id/et_attendance_reason"
                         style="@style/TEXT_MEDIUM_BLACK_10"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:gravity="start|top"
                         android:inputType="textMultiLine"
                         android:minLines="4"
                         android:maxLines="8"
                         android:singleLine="false"
                         tools:text=""
                         android:hint="@string/write_reason"
                         android:textColorHint="@color/grey" />

                 </com.google.android.material.textfield.TextInputLayout>


             </androidx.constraintlayout.widget.ConstraintLayout>


         </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.constraintlayout.widget.ConstraintLayout

            android:id="@+id/cv_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/bottom_guideline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            >
            <com.axelliant.hris.components.RoundedButton
                android:id="@+id/btn_apply"
                style="@style/ButtonTextStyle"
                android:layout_width="0dp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                app:buttonBg="@drawable/rounded_enabled"
                app:iconVisibility="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:text="@string/apply"
                android:visibility="visible"
                app:textColor="@color/white" />


            <com.axelliant.hris.components.RoundedButton
                android:id="@+id/btn_update"
                style="@style/ButtonTextStyle"
                android:layout_width="0dp"
                android:layout_height="@dimen/_40sdp"
                app:buttonBg="@drawable/rounded_enabled"
                app:iconVisibility="false"
                android:layout_marginStart="@dimen/_15sdp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_deleted"
                app:layout_constraintStart_toStartOf="parent"
                app:text="@string/update"
                android:visibility="gone"

                app:textColor="@color/white" />


            <com.axelliant.hris.components.RoundedButton
                android:id="@+id/btn_deleted"
                style="@style/ButtonTextStyle"
                android:layout_width="0dp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                app:buttonBg="@drawable/rounded_leave_cancelled"
                app:iconVisibility="false"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/btn_update"
                app:text="@string/delete"
                app:textColor="@color/black" />
        </androidx.constraintlayout.widget.ConstraintLayout>





    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
