        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Demo</item>
    </style>

    <!-- this is for your dialog. To make round corners -->
    <style name="alert_dialog_round_corners" parent="@style/Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:buttonBarButtonStyle">@style/alert_dialog_button_style</item>
    </style>
    <!-- this one is for your buttons. To make them NOT TRANSPARENT -->
    <style name="alert_dialog_button_style" parent="">
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:background">@drawable/alert_dialog_button_background</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <!-- Toggle group container: gray pill background, no dividers -->
    <style name="LeaveFilterToggleGroup" parent="Widget.MaterialComponents.MaterialButtonToggleGroup">
        <item name="android:background">@drawable/bg_filter_toggle_track</item>
        <item name="android:padding">4dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Individual toggle button: transparent bg, becomes white when checked -->
    <style name="LeaveFilterButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/selector_toggle_text</item>
        <item name="backgroundTint">@color/selector_toggle_bg</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
